# Copy this file to .env and fill in your values.
# .env is excluded from git – never commit real credentials.

# Hostname or IP of the Tenable Security Center appliance
SC_HOST=securitycenter.example.com

# API key pair – generate in Security Center under:
# Users > Your Profile > API Keys > Generate
SC_ACCESS_KEY=your-access-key-here
SC_SECRET_KEY=your-secret-key-here

# Keep "true" for any real appliance. Only set to "false" for a lab/dev
# instance with a self-signed certificate that you cannot otherwise trust —
# disabling TLS verification removes protection against MITM on every request.
SC_VERIFY_SSL=true
