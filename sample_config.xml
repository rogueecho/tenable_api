<?xml version="1.0" encoding="UTF-8"?>
<!--
  sample_config.xml
  Example Security Center configuration export for use with xml_to_baseline.py.

  Section tag names (config, system_info, status) must match the keys
  returned by collect_config_report() in tenable_sc.py.

  Convert to a baseline YAML:
      python xml_to_baseline.py sample_config.xml
      python xml_to_baseline.py sample_config.xml -t 20%
      python xml_to_baseline.py sample_config.xml -e smtpHost,smtpFromAddress
-->
<SecurityCenterConfig
    version="1.0"
    host="securitycenter.example.com"
    exported="2026-05-26T00:00:00Z">

  <Metadata>
    <Description>Production Security Center baseline — Q2 2026</Description>
  </Metadata>

  <!-- Platform configuration from the /config endpoint -->
  <config>
    <smtpHost>smtp.example.com</smtpHost>
    <smtpPort>25</smtpPort>
    <smtpEncryption>TLS</smtpEncryption>
    <smtpFromAddress>noreply@example.com</smtpFromAddress>
    <smtpFromName>Tenable Security Center</smtpFromName>
    <smtpAuthType>NONE</smtpAuthType>
    <ldapEnabled>true</ldapEnabled>
    <ldapHost>ldap.example.com</ldapHost>
    <ldapPort>636</ldapPort>
    <ldapEncryption>LDAPS</ldapEncryption>
    <samlEnabled>false</samlEnabled>
    <sessionTimeout>30</sessionTimeout>
    <allowUserManagement>true</allowUserManagement>
  </config>

  <!-- System information from the /system endpoint -->
  <system_info>
    <licenseStatus>Valid</licenseStatus>
    <licenseType>Subscription</licenseType>
    <version>6.3.0</version>
  </system_info>

  <!-- Feed and plugin status from the /status endpoint -->
  <status>
    <feedStatus>Current</feedStatus>
    <updateRunning>false</updateRunning>
  </status>

  <!--
    Alternative flat Setting style — some exporters emit a flat list instead
    of nested sections.  Both formats can coexist in the same file.
    The 'section' attribute defaults to "config" if omitted.

    <Settings>
      <Setting name="sessionTimeout" value="30"    section="config"/>
      <Setting name="ldapEnabled"    value="true"  section="config"/>
      <Setting name="licenseStatus"  value="Valid" section="system_info"/>
    </Settings>
  -->


</SecurityCenterConfig>
